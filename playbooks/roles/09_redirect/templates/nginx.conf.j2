events {
  worker_connections  4096;  ## Default: 1024
}
http{
    server {
        listen 80;
        server_name {{ redirection_sub_domain_1 }}.{{ domain }};

        location / {
            proxy_pass https://{{ redirection_url_1 }};
            proxy_ssl_verify off;
            proxy_set_header Host {{ redirection_url_1 }};
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
    }

    server {
        listen 80;
        server_name {{ redirection_sub_domain_2 }}.{{ domain }};

        location / {
            proxy_pass https://{{ redirection_url_2 }};
            proxy_ssl_verify off;
            proxy_set_header Host {{ redirection_url_2 }};
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}