services:
  homeserver:
    image: "forgejo.ellis.link/continuwuation/continuwuity:v0.5.10"
    restart: unless-stopped
    command: /sbin/conduwuit
    volumes:
      - db-conduwuit:/var/lib/continuwuity
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.continuwuity.rule=(Host(`{{messaging_sub_domain}}.{{domain}}`))"
      - "traefik.http.routers.continuwuity.entrypoints=websecure"
      - "traefik.http.routers.continuwuity.tls=true"
      - "traefik.http.routers.continuwuity.service=continuwuity"
      - "traefik.http.services.continuwuity.loadbalancer.server.port=8008"
      - "traefik.http.routers.continuwuity.tls.certresolver=letsencrypt-dns"
    environment:
      CONTINUWUITY_SERVER_NAME: "{{messaging_sub_domain}}.{{domain}}"
      CONTINUWUITY_DATABASE_PATH: /var/lib/continuwuity
      CONTINUWUITY_ADDRESS: 0.0.0.0
      CONTINUWUITY_PORT: 8008
      CONTINUWUITY_WELL_KNOWN: |
        {
        client=https://{{messaging_sub_domain}}.{{domain}},
        server={{messaging_sub_domain}}.{{domain}}:443
        }

  element:
    image: vectorim/element-web:v1.12.13
    restart: unless-stopped
    volumes:
      - ./element-config.json:/app/config.json
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.element.rule=Host(`{{element_sub_domain}}.${DOMAIN}`)"
      - "traefik.http.routers.element.entrypoints=websecure"
      - "traefik.http.services.element.loadbalancer.server.port=80"
      - "traefik.http.routers.element.tls=true"
      - "traefik.http.routers.element.tls.certresolver=letsencrypt-dns"

  hookshot:
    image: ghcr.io/matrix-org/matrix-hookshot:7.4.2
    restart: unless-stopped
    volumes:
      - ./hook-config.yml:/data/config.yml:ro
      - ./registration.yml:/data/registration.yml:ro
      - ./passkey.pem:/usr/bin/matrix-hookshot/passkey.pem
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ traefik_network }}"
      - "traefik.http.routers.hookshot.rule=Host(`hook.{{ domain }}`)"
      - "traefik.http.routers.hookshot.entrypoints=websecure"
      - "traefik.http.routers.hookshot.tls.certresolver=letsencrypt-dns"
      - "traefik.http.services.hookshot.loadbalancer.server.port=9000"

  alert-relay:
    image: python:3.10.20-alpine3.24
    restart: unless-stopped
    command: python /app/alert-webhook-relay.py
    volumes:
      - ./alert-webhook-relay.py:/app/alert-webhook-relay.py:ro
    environment:
      HOOKSHOT_BASE_URL: "http://hookshot:9000"
      PORT: "9094"
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ traefik_network }}"
      - "traefik.http.routers.alert-relay.rule=Host(`alert-relay.{{ domain }}`)"
      - "traefik.http.routers.alert-relay.entrypoints=websecure"
      - "traefik.http.routers.alert-relay.tls=true"
      - "traefik.http.routers.alert-relay.tls.certresolver=letsencrypt-dns"
      - "traefik.http.services.alert-relay.loadbalancer.server.port=9094"

volumes:
  db-conduwuit:

networks:
  default:
    external: true
    name: "{{ traefik_network }}"
