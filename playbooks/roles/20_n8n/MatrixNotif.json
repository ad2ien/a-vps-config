        "jsCode": "const item = $input.all()[0].json;\nconst data = item.body || item;\nconst query = item.query;\n\nconst icons = {\n  info: \"ℹ️\",\n  success: \"✅\",\n  warning: \"⚠️\",\n  error: \"🚨\"\n};\n\nconst icon = icons[data.type] || \"📢\";\nconst lines = [`${icon} ${data.title || \"Notification\"}`];\n\nif (data.message) lines.push(data.message);\nif (data.environment) lines.push(`Environment: ${data.environment}`);\n\nreturn {\n  room_id: query.room,\n  text: lines.join(\"\\n\"),\n  msgtype: \"m.text\"\n};"
