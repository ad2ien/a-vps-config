    {
      "parameters": {
        "jsCode": "const item = $input.all()[0].json;\nconst data = item.body;\nconst query = item.query;\nconst room = query && query.room ? `${query.room}` : \"\";\n\nconst status = data.status || \"unknown\";\nconst alertname = (data.groupLabels && data.groupLabels.alertname) || \"Unknown\";\nconst prefix = status === \"resolved\" ? \"✅ RESOLVED\" : \"🔥 FIRING\";\nconst lines = [`${prefix}: ${alertname}`];\n\nfor (const alert of data.alerts || []) {\n  const ann = alert.annotations || {};\n  const mountpoint = (alert.labels && alert.labels.mountpoint) || \"\";\n  const desc = ann.description || \"\";\n  if (desc) lines.push(`  • ${mountpoint} ${desc}`);\n}\n\nreturn {\n  room_id: room,\n  text: lines.join(\"\\n\"),\n  msgtype: \"m.text\"\n};"
      },
