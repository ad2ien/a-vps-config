name: {{ tenant }}-n8n
services:
  postgres:
    image: postgres:18.4-alpine3.24
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${DB_POSTGRESDB_USER}
      POSTGRES_PASSWORD: ${DB_POSTGRESDB_PASSWORD}
      POSTGRES_DB: ${DB_POSTGRESDB_DATABASE}
    volumes:
      - n8n-db:/var/lib/postgresql/18/docker
    networks:
      - n8n-internal
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5

  n8n:
    image: n8nio/n8n:2.29.0
    restart: unless-stopped
    env_file: .env
    volumes:
      - n8n-data:/home/node/.n8n
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ traefik_network }}"
      - "traefik.http.routers.n8n-{{ tenant }}.rule=Host(`{{ n8n_subdomain }}.{{ tenant }}.{{ domain }}`)"
      - "traefik.http.routers.n8n-{{ tenant }}.entrypoints=websecure"
      - "traefik.http.services.n8n-{{ tenant }}.loadbalancer.server.port=5678"
      - "traefik.http.routers.n8n-{{ tenant }}.tls.certresolver=letsencrypt"
    networks:
      - traefik
      - n8n-internal
    depends_on:
      n8n-postgres:
        condition: service_healthy

volumes:
  "n8n-db":
  "n8n-data":

networks:
  n8n-internal:
  traefik:
    external: true
    name: {{ traefik_network }}
