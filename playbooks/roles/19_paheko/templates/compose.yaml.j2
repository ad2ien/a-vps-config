name: {{ tenant }}-paheko
services:
  paheko:
    image: paheko/paheko:1.3.20
    restart: unless-stopped
    volumes:
      - ./config.local.php:/var/www/paheko/config.local.php
      - ./php.ini:/usr/local/etc/php/php.ini
      - pahekodata:/var/www/paheko/data
      - plugins:/var/www/paheko/data/plugins
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ traefik_network }}"
      - "traefik.http.routers.paheko-{{ tenant }}.rule=Host(`{{ paheko_subdomain }}.{{ tenant }}.{{ domain }}`)"
      - "traefik.http.routers.paheko-{{ tenant }}.entrypoints=websecure"
      - "traefik.http.services.paheko-{{ tenant }}.loadbalancer.server.port=80"
      - "traefik.http.routers.paheko-{{ tenant }}.tls.certresolver=letsencrypt"

volumes:
  "db":
  "pahekodata":
  "plugins":

networks:
  default:
    external: true
    name: {{ traefik_network }}
